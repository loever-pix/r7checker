# R6Checker full-stack source — example env
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Runs three components off ONE codebase: website, Discord bot, desktop checker.

# ─── Site (server.js on :3000) ────────────────────────────────────────────────
SITE_URL=http://localhost:3000
PORT=3000

# Owner identification — comma-separated list of emails treated as owner accounts.
OWNER_EMAILS=owner@example.com

# Cookie/session signing — 32 random bytes hex.
# Generate: node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
SITE_SESSION_SECRET=

# AES-256-GCM key for on-disk result-file encryption — 64 hex chars (32 bytes).
# Generate: node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
RESULTS_ENC_KEY=

# ─── Rotating proxy gateway ──────────────────────────────────────────────────
# Any residential/mobile gateway with per-request session tokens works.
# Recognized by hostname:  DataImpulse → __sid-<rand>,  FlameProxies → -session-<rand>.
# Others: set BULK_PROXY_SESSION_PARAM below.
USE_PROXY=true
PROXY_HOST=proxy.example.com
PROXY_PORT=8080
PROXY_USER=your-gateway-user
PROXY_PASS=your-gateway-pass
# Optional: override the session-token template — {rand} is replaced per request.
# BULK_PROXY_SESSION_PARAM=-sessid-{rand}
# BULK_PROXY_ROTATE=off             # kill switch (disables session rotation)

# Optional: dedicated tracker.gg proxy pool (separate credentials from the main
# residential pool — DataImpulse/FlameProxies both work).
# TRACKER_PROXY_URL=http://user:pass@proxy.example.com:8080
# TRACKER_PROXY_COUNTRY=us

# ─── Third-party rank source (optional, decorative) ───────────────────────────
# r6data.com API key. The checker falls through to tracker.gg + Ubisoft-native
# if this is empty — leaving it blank is fine.
R6DATA_KEY=

# ─── Anti-mask + rate governor (safe defaults; only change if you understand) ─
R6_LOGIN_ATTEMPTS=6                     # login-loop retries per account
BULK_NETWORK_RETRIES=1                  # outer-attempt retries
BULK_401_VERIFY=1                       # verify suspicious 401s on fresh state
BULK_MAX_CONCURRENCY=600                # per-child governor max
BULK_WORKER_CONCURRENCY=200             # coroutines per forked child
BULK_WORKERS=4                          # forked worker processes
BULK_GOV_INITIAL_CONCURRENCY=200        # slow-start ceiling
BULK_GOV_MIN_CONCURRENCY=32             # floor under 429 pressure
BULK_GOV_INCREASE_STEP=16               # AIMD +step per interval
BULK_GOV_INCREASE_INTERVAL_MS=500

# ─── Discord bot (bot.js) ─────────────────────────────────────────────────────
DISCORD_TOKEN=                          # bot token from the Discord Developer Portal
DISCORD_CLIENT_ID=                      # for slash-command registration
DISCORD_GUILD_ID=                       # your server's ID
OWNER_DISCORD_ID=000000000000000000     # Discord user id of the owner (18-digit snowflake)
# Role IDs that can invoke /recheck (comma-separated).
RECHECK_ROLE_IDS=000000000000000000

# Bot ↔ site auth: shared secret so the bot can POST to /api/admin/bot/*.
BOT_API_TOKEN=
BOT_INBOUND_TOKEN=                      # if the site pushes back to the bot

# ─── SellAuth (Discord bot's storefront integration) ─────────────────────────
SELLAUTH_API_KEY=
SELLAUTH_SHOP_ID=

# ─── Whop (card-payment provider) ─────────────────────────────────────────────
WHOP_API_KEY=
WHOP_COMPANY_ID=
WHOP_WEBHOOK_SECRET=                    # for HMAC-SHA256 verification of inbound webhooks

# ─── Ubisoft API tuning (usually leave defaults) ─────────────────────────────
UBI_CONCURRENCY=30
UBI_RPS=40
UBI_TIMEOUT=12000                       # ms per Ubi request

# ─── Ubi AppId pool (usually leave defaults) ─────────────────────────────────
# STRICT_APPIDS=0 disables the older strict pool (100% DataDome-blocked as of 2026).

# ─── Desktop checker specific ────────────────────────────────────────────────
R6_OWNER_EMAIL=owner@example.com        # owner account for the desktop app
# R6_BRAND=r6checker                    # build brand: 'r6checker' or 'ubivm'
# R6_LICENSE_KEY=                       # for headless activation
# R6_NO_TRACKER=1                       # bulk force-native (no tracker.gg calls)
# CHECKER_SERVER=https://r6checker.xyz  # override activation server URL
